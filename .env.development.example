# Development Environment Variables
# Copy this file to .env and fill in your values

# Google OAuth Configuration (optional for development)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# PocketBase Admin Account (optional, defaults provided)
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=admin123

# Frontend Development URLs (defaults provided in docker-compose.dev.yml)
VITE_API_BASE_URL=http://localhost:8090
VITE_BROUTER_BASE_URL=http://localhost:17777